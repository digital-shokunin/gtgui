FROM ubuntu:24.04

# System deps + locale support for Unicode box-drawing characters
RUN apt-get update && apt-get install -y --no-install-recommends \
    tmux curl git ca-certificates nodejs npm locales \
    && rm -rf /var/lib/apt/lists/* \
    && sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen \
    && locale-gen

ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Create non-root claude user with uid 1000 to match host claude user
# This ensures mounted .claude files (credentials, settings, skills) are readable
RUN userdel -r ubuntu 2>/dev/null; useradd -m -s /bin/bash -u 1000 claude

# Supply chain hardening (Trail of Bits)
ENV NPM_CONFIG_IGNORE_SCRIPTS=true
ENV NPM_CONFIG_AUDIT_LEVEL=critical
ENV PIP_REQUIRE_HASHES=true
ENV PIP_NO_CACHE_DIR=true

# Deny sensitive paths via Claude config (applied at runtime via mount)
# ~/.claude/settings.json mounted read-only from host

RUN mkdir /workspace && chown claude:claude /workspace

USER claude

# Pre-complete Claude Code onboarding so theme picker doesn't appear in terminal
RUN echo '{"hasCompletedOnboarding":true,"theme":"dark"}' > /home/claude/.claude.json

WORKDIR /workspace

# Keep container alive (tmux sessions run inside)
CMD ["sleep", "infinity"]
